# Development files
.vscode/**
.vscode-test/**
.gitignore
.yarnrc
vsc-extension-quickstart.md
**/jsconfig.json
**/*.map
**/.eslintrc.json

# Documentation (except required)
**/*.md
!README.md
!CHANGELOG.md

# Build files (bundled into dist/)
esbuild.js
src/**
extension.js
scripts/**
build/**

# Tests and dev configs (not needed by end users)
tests/**
vitest.config.js
renovate.json
.mcp.json

# Dependencies. esbuild bundles everything except playwright-core,
# which must ship as a real package directory so its runtime
# require(packageRoot/browsers.json) and require(packageRoot/package.json)
# resolve correctly (packageRoot is computed from __dirname of the
# playwright-core lib, not the bundled extension.js).
#
# We ship the FULL playwright-core directory (lib/, bin/, types/ - all
# 106 files, ~13MB uncompressed / ~3MB compressed inside the VSIX). The
# total VSIX is ~5MB which is well within marketplace limits, and
# shipping every file removes a whole class of "missing module at
# runtime" bugs. Do not try to slim playwright-core - see STATE.md
# "Bundle the entire playwright-core package, no slimming" decision.
node_modules/**
!node_modules/playwright-core/**

# Keep bundled output
!dist/**

# Project management
.claude/**
STATE.md
TODO.md
archive/**
*.vsix

