# Development files
.vscode/**
.vscode-test/**
.gitignore
.yarnrc
vsc-extension-quickstart.md
**/jsconfig.json
**/*.map
**/.eslintrc.json

# Documentation (except required)
**/*.md
!README.md
!CHANGELOG.md

# Build files (bundled into dist/)
esbuild.js
src/**
extension.js
scripts/**
build/**

# Logo generator + its bundled font/icons (build-time only, not shipped).
# The generated assets/*.png|svg still ship for the icon + README.
assets/src/**
.tmp/**
.ruff_cache/**

# Tests and dev configs (not needed by end users)
tests/**
vitest.config.js
renovate.json
.mcp.json

# Dependencies. esbuild bundles the extension into dist/, and there are no
# runtime dependencies to ship, so node_modules is fully excluded.
node_modules/**

# Keep bundled output
!dist/**

# Project management
.claude/**
STATE.md
TODO.md
archive/**
*.vsix

# AI tooling (local dev only)
ai/**
hyperi-ai/**
.gitmodules
CLAUDE.md
.cursorrules
.cursor/**
CODEX.md
.codex/**
GEMINI.md
.gemini/**
SKILLS.md

# Dev tooling
eslint.config.js
.github/**

# Git config files
.gitleaks.toml
.releaserc.json
