# Development files
.vscode/**
.vscode-test/**
.gitignore
.yarnrc
vsc-extension-quickstart.md
**/jsconfig.json
**/*.map
**/.eslintrc.json

# Documentation (except required)
**/*.md
!README.md
!CHANGELOG.md

# Build files (bundled into dist/)
esbuild.js
src/**
extension.js
scripts/**
build/**

# Tests and dev configs (not needed by end users)
tests/**
vitest.config.js
renovate.json
.mcp.json

# Dependencies — esbuild bundles everything except playwright-core,
# which must ship as a real package directory so its runtime
# `require(packageRoot/browsers.json)` and `require(packageRoot/package.json)`
# resolve correctly (packageRoot is computed from __dirname of the
# playwright-core lib, not the bundled extension.js).
node_modules/**
!node_modules/playwright-core/**
# Drop TypeScript .d.ts files — never loaded at runtime
node_modules/playwright-core/types/**

# Keep bundled output
!dist/**

# Project management
.claude/**
STATE.md
TODO.md
archive/**
*.vsix

# AI tooling (local dev only)
ai/**
hyperi-ai/**
.gitmodules
CLAUDE.md
.cursorrules
.cursor/**
CODEX.md
.codex/**
GEMINI.md
.gemini/**
SKILLS.md

# Dev tooling
eslint.config.js
.github/**

# Git config files
.gitleaks.toml
.releaserc.json
